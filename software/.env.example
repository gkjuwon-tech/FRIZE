# FRIZE 환경 변수 예시 (.env 로 복사해서 사용)

# 메시지 버스
FRIZE_MQTT_HOST=localhost
FRIZE_MQTT_PORT=1883

# 코어 HTTP/WS
FRIZE_HTTP_PORT=8000

# 사이트 원점(출동 지점)
FRIZE_SITE_LAT=37.5665
FRIZE_SITE_LON=126.9780
FRIZE_SITE_ALT=30.0

# VLM 판단 계층(Anthropic). 비우면 감지 없이 동작.
ANTHROPIC_API_KEY=
FRIZE_VLM_MODEL=claude-opus-4-8
FRIZE_VLM_ENABLED=true

# 디바이스(시뮬) ― 샘플 프레임을 주면 코어 VLM이 실제로 판단함
FRIZE_SIM_FRAME=apps/frize_cockpit/assets/fireground.jpg

# 드론 실제 비행제어 시
# FRIZE_FLIGHT_BACKEND=mavsdk
# FRIZE_MAVLINK_URL=udp://:14540

# 콕핏 → 코어
FRIZE_CORE_WS=ws://localhost:8000/ws/cockpit
